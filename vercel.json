{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && cd ape && npm install",
  "buildCommand": "cd ape && npm run build",
  "outputDirectory": "ape/build",
  "rewrites": [
    {
      "source": "/api/personnel/(.*)",
      "destination": "/api/personnel/[...slug].js"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  }
}
