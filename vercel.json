{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && cd ape && npm install",
  "buildCommand": "cd ape && npm run build",
  "outputDirectory": "ape/build",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
